      "priority": "Medium",
      "sla": "24-48 hours",
      "team": "Finance Team",
      "escalation_rules": {
        "urgent_keywords": ["overdue", "late payment", "audit", "compliance"]
      }
    },
    {
      "name": "Operations",
      "keywords": ["operations", "logistics", "shipping", "delivery", "inventory", "supply chain", "vendor", "procurement"],
      "priority": "Medium",
      "sla": "24-48 hours",
      "team": "Operations Team",
      "escalation_rules": {
        "urgent_keywords": ["delayed", "shortage", "critical supply"]
      }
    },
    {
      "name": "Strategic",
      "keywords": ["strategy", "partnership", "acquisition", "investment", "board", "executive", "ceo", "cfo", "cto"],
      "priority": "Critical",
      "sla": "2-4 hours",
      "team": "Executive Team",
      "escalation_rules": {
        "urgent_keywords": ["confidential", "urgent", "board meeting"],
