{
  "$schema": "yos-bus-entry-backend-registry-v1.1.0",
  "canonical_module": "YOS BUS",
  "entry_abstraction": "BUS.write(packet)",
  "census_gate": "MPM-20260705-YOS-MANUS-CONNECTIVITY-CENSUS-GATE",
  "env": {
    "backend": "YOS_BUS_ENTRY_BACKEND",
    "runtime_root": "YOS_BUS_RUNTIME_ROOT"
  },
  "preferred_order": [
    "direct_file",
    "manus_api_task",
    "git",
    "connector_bridge",
    "mcp_bridge",
    "manual_upload",
    "blob_payload"
  ],
  "backends": {
    "direct_file": {
      "status": "production_ready",
      "versioned": false,
      "transport_commit_required": false,
      "persistent_path": "/home/ubuntu/yos-bus-runtime",
      "cross_session_persistence": "proven",
      "latency": "~1ms",
      "probe_gate": "MPM-20260705-YOS-BUS-DIRECT-FILE-RUNTIME-PROBE-GATE",
      "notes": "Canonical backend. Full lifecycle supported. Cross-session persistence proven. External write requires manual_upload bridge or manus_api_task relay."
    },
    "manus_api_task": {
      "status": "production_candidate",
      "versioned": false,
      "transport_commit_required": false,
      "endpoint": "POST https://api.manus.ai/v2/task.create",
      "auth": "x-manus-api-key",
      "rate_limit": "10/min",
      "latency": "seconds (async)",
      "cross_session_persistence": "task-scoped",
      "probe_gate": "MPM-20260705-YOS-MANUS-CONNECTIVITY-CENSUS-GATE",
      "notes": "ChatGPT calls task.create with packet as message → Manus agent relays to BUS inbox. Recommended external write path upgrade. Async."
    },
    "connector_bridge": {
      "status": "production_candidate",
      "versioned": false,
      "transport_commit_required": false,
      "connectors_available": 252,
      "connectors_enabled": 0,
      "notable": ["GitHub", "Google Drive", "Notion"],
      "probe_gate": "MPM-20260705-YOS-MANUS-CONNECTIVITY-CENSUS-GATE",
      "notes": "If GitHub or Google Drive connector enabled, provides programmatic transport. Requires connector auth setup."
    },
    "mcp_bridge": {
      "status": "candidate",
      "versioned": false,
      "transport_commit_required": false,
      "cli": "/usr/local/bin/manus-mcp-cli",
      "servers_configured": 0,
      "probe_gate": "MPM-20260705-YOS-MANUS-CONNECTIVITY-CENSUS-GATE",
      "notes": "High potential if filesystem MCP server configured at /home/ubuntu/yos-bus-runtime. Enables direct write from external LLM via MCP protocol."
    },
    "git": {
      "status": "production_ready",
      "versioned": true,
      "transport_commit_required": true,
      "repo": "yj000018/YOS",
      "branch": "main",
      "latency": "seconds to minutes",
      "cross_session_persistence": "permanent",
      "notes": "Proven canonical fallback. Versioned, auditable. External write proven (ChatGPT has GitHub access). Slower than filesystem."
    },
    "manual_upload": {
      "status": "operational_bridge",
      "versioned": false,
      "transport_commit_required": false,
      "notes": "Human uploads MP file to Manus; bus.py ingest places it into BUS inbox. Current operational bridge. Eliminates with manus_api_task upgrade."
    },
    "blob_payload": {
      "status": "experimental",
      "versioned": false,
      "transport_commit_required": false,
      "ttl": "48h",
      "cdn": "files.manuscdn.com",
      "notes": "S3 CDN upload. One-shot delivery only. No lifecycle support. 48h TTL. Emergency use only."
    }
  }
}
