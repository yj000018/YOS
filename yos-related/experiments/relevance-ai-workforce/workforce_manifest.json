          "label": "Priority Check",
          "position": {
            "x": 500,
            "y": 500
          },
          "conditions": [
            {
              "name": "Urgent",
              "rule": "priority == 'urgent' or priority == 1",
              "target": "strategist_agent"
            },
            {
              "name": "Standard",
              "rule": "priority != 'urgent' and priority != 1",
              "target": "output"
            }
          ]
        }
      ],
      "connections": [
        {
          "from": "trigger_1",
          "to": "worker_agent",
          "label": "Start processing"
        },
        {
          "from": "worker_agent",
          "to": "coo_agent",
