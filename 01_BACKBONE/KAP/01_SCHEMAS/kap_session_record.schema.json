{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "kap_session_record.schema.json",
  "title": "KAP Session Record",
  "description": "Normalized session record produced by a Knowledge Adapter",
  "type": "object",
  "required": ["source_id", "adapter_id", "session_id", "status"],
  "properties": {
    "source_id": {"type": "string"},
    "adapter_id": {"type": "string"},
    "session_id": {"type": "string", "description": "KAP internal session ID"},
    "external_session_id": {"type": ["string", "null"], "description": "Provider-native session ID"},
    "status": {"type": "string", "enum": ["active", "checkpointed", "finalized", "archived", "unknown"]},
    "created_at": {"type": ["string", "null"], "format": "date-time"},
    "updated_at": {"type": ["string", "null"], "format": "date-time"},
    "finalized_at": {"type": ["string", "null"], "format": "date-time"},
    "checkpoint_cursor": {"type": ["string", "null"]},
    "title": {"type": ["string", "null"]},
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "role": {"type": "string", "enum": ["user", "assistant", "system", "tool"]},
          "content": {"type": "string"},
          "timestamp": {"type": ["string", "null"], "format": "date-time"}
        }
      }
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "attachment_id": {"type": "string"},
          "filename": {"type": "string"},
          "mime_type": {"type": "string"},
          "size_bytes": {"type": ["integer", "null"]},
          "content_url": {"type": ["string", "null"]}
        }
      }
    },
    "coverage": {
      "type": "object",
      "properties": {
        "level": {"type": "string", "enum": ["minimal", "partial", "broad", "near_exhaustive", "exhaustive"]},
        "known_gaps": {"type": "array", "items": {"type": "string"}}
      }
    },
    "metadata": {"type": "object", "description": "Adapter-specific metadata"}
  }
}
