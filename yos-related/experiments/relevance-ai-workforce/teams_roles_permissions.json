  "global_permissions": {
    "all_teams_can": [
      "View assigned emails",
      "Update task status in Notion",
      "Communicate with other teams",
      "Escalate urgent issues",
      "Access knowledge base"
    ],
    "restricted": [
      "Access other teams' emails (except Executive)",
      "Modify system configuration",
      "Delete records",
      "Override SLA settings"
    ]
  },
  "integration_permissions": {
    "notion": {
      "all_teams": ["read", "write", "create_tasks"],
      "executive_only": ["delete", "modify_structure", "admin_access"]
    },
    "gmail": {
      "all_teams": ["read_assigned", "send", "reply"],
      "executive_only": ["read_all", "admin_access"]
    }
