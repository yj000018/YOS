{
  "name": "y-menu",
  "version": "0.1.0",
  "description": "Y-Menu — Cognitive Orchestration Interface for Y-OS",
  "main": "dist/cli.js",
  "scripts": {
    "build": "tsc",
    "demo": "ts-node src/cli.ts demo",
    "menu": "ts-node src/cli.ts menu",
    "menu:book": "ts-node src/cli.ts menu book-factory",
    "intent:kindle": "ts-node src/cli.ts intent \"produce kindle version\"",
    "intent:site": "ts-node src/cli.ts intent \"create mini-site for my book\"",
    "status": "ts-node src/cli.ts status",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch"
  },
  "keywords": ["y-os", "y-menu", "cognitive-interface", "book-factory", "publishing"],
  "author": "Yannick Jolliet",
  "license": "MIT",
  "dependencies": {
    "js-yaml": "^4.1.0",
    "chalk": "^4.1.2",
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "@types/jest": "^29.5.11",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"],
    "moduleFileExtensions": ["ts", "js", "json"]
  }
}
