    {
      "id": "sales_team",
      "name": "Sales Team",
      "role": "Sales & Customer Acquisition",
      "members": [],
      "permissions": {
        "email_access": ["sales@", "leads@", "demo@"],
        "notion_access": ["Sales Database", "Leads Pipeline", "Customer Records"],
        "tools": ["CRM", "Email", "Calendar", "Notion", "Gmail"],
        "actions": ["read_emails", "send_emails", "create_tasks", "update_crm", "schedule_meetings"]
      },
      "workflow": {
        "receives_from": "COO Agent",
        "category": "Sales",
        "priority_levels": [1, 2, 3, 4],
        "sla": {
          "urgent": "4 hours",
          "high": "12 hours",
          "medium": "24 hours",
          "low": "48 hours"
        },
        "escalation": {
          "after": "24 hours",
          "to": "Sales Manager"
        }
      },
      "metrics": {
        "response_time": {"target": "< 4 hours", "unit": "hours"},
        "conversion_rate": {"target": "> 25%", "unit": "percentage"},
        "deal_size": {"target": "> $10,000", "unit": "USD"},
        "customer_satisfaction": {"target": "> 90%", "unit": "percentage"}
      }
    },
