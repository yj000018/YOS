{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "kap_coverage_report.schema.json",
  "title": "KAP Coverage Report",
  "description": "Coverage report for a KAP source — tracks what has been captured vs what is known to exist",
  "type": "object",
  "required": ["report_id", "adapter_id", "source_id", "generated_at", "coverage_level"],
  "properties": {
    "report_id": {"type": "string"},
    "adapter_id": {"type": "string"},
    "source_id": {"type": "string"},
    "generated_at": {"type": "string", "format": "date-time"},
    "coverage_level": {
      "type": "string",
      "enum": ["minimal", "partial", "broad", "near_exhaustive", "exhaustive"],
      "description": "Overall coverage assessment"
    },
    "total_known_records": {"type": ["integer", "null"]},
    "records_captured": {"type": "integer", "minimum": 0},
    "records_finalized": {"type": "integer", "minimum": 0},
    "records_pending": {"type": "integer", "minimum": 0},
    "date_range": {
      "type": "object",
      "properties": {
        "earliest_captured": {"type": ["string", "null"], "format": "date-time"},
        "latest_captured": {"type": ["string", "null"], "format": "date-time"},
        "earliest_known": {"type": ["string", "null"], "format": "date-time"},
        "latest_known": {"type": ["string", "null"], "format": "date-time"}
      }
    },
    "known_gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "gap_id": {"type": "string"},
          "description": {"type": "string"},
          "severity": {"type": "string", "enum": ["critical", "high", "medium", "low"]},
          "resolution": {"type": ["string", "null"]}
        }
      }
    },
    "last_checkpoint_cursor": {"type": ["string", "null"]},
    "recommended_next_action": {"type": "string"},
    "notes": {"type": ["string", "null"]}
  }
}
