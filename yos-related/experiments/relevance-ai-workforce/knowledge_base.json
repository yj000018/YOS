{
  "name": "Email Management System Knowledge Base",
  "description": "Complete knowledge base for email processing, categorization, and workflow management",
  "version": "1.0.0",
  "categories": [
    {
      "name": "Sales",
      "keywords": ["sales", "lead", "prospect", "demo", "pricing", "quote", "proposal", "customer", "revenue", "deal"],
      "priority": "High",
      "sla": "4-24 hours",
      "team": "Sales Team",
      "escalation_rules": {
        "urgent_keywords": ["urgent", "asap", "immediately", "today"],
        "vip_domains": ["enterprise.com", "fortune500.com"]
      }
    },
    {
      "name": "Support",
